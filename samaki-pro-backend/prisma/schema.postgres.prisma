generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum UserRole {
  FARMER
  VENDOR
  ADMIN
}

enum ListingStatus {
  AVAILABLE
  SOLD
  PENDING
}

enum OrderStatus {
  PENDING
  ESCROW_FUNDED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique // Links to Supabase Auth User ID
  fullName  String?
  role      UserRole @default(FARMER)
  phone     String?  // International format: +255...
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings     Listing[]
  buyerOrders  Order[]   @relation("BuyerOrders")
  sellerOrders Order[]   @relation("SellerOrders")
  cages        Cage[]

  @@map("profiles")
}

model Listing {
  id          String        @id @default(uuid())
  title       String
  description String?
  price       Decimal       @db.Decimal(10, 2)
  quantity    Int
  unit        String        // e.g., "kg", "ton"
  imageUrl    String?
  status      ListingStatus @default(AVAILABLE)
  sellerId    String
  seller      Profile       @relation(fields: [sellerId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  orders Order[]

  @@map("listings")
}

model Order {
  id          String      @id @default(uuid())
  buyerId     String
  buyer       Profile     @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId    String
  seller      Profile     @relation("SellerOrders", fields: [sellerId], references: [id])
  listingId   String
  listing     Listing     @relation(fields: [listingId], references: [id])
  quantity    Int
  unitPrice   Decimal     @db.Decimal(10, 2)
  totalAmount Decimal     @db.Decimal(10, 2)
  escrowId    String?
  transactionId String?
  paymentProvider String? // MPESA, TIGOPESA
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("orders")
}

model Escrow {
  id            String   @id @default(uuid())
  orderId       String   @unique
  buyerId       String
  sellerId      String
  amount        Decimal  @db.Decimal(10, 2)
  transactionId String?
  status        String   @default("AWAITING_PAYMENT") // AWAITING_PAYMENT, FUNDS_HELD, RELEASED_TO_SELLER, REFUNDED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("escrows")
}

model Cage {
  id          String   @id @default(uuid())
  name        String
  type        String   // "circular", "rectangular"
  length      Float?
  width       Float?
  depth       Float?
  capacity    Int?     // Max fish capacity
  location    String?  // GPS coordinates or description
  farmerId    String
  farmer      Profile  @relation(fields: [farmerId], references: [id])
  status      String   @default("ACTIVE") // ACTIVE, MAINTENANCE, INACTIVE
  
  batches     Batch[]
  sensors     SensorReading[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cages")
}

model Batch {
  id          String   @id @default(uuid())
  cageId      String
  cage        Cage     @relation(fields: [cageId], references: [id])
  species     String   // "Tilapia", "Nile Perch"
  quantity    Int      // Initial stocking quantity
  currentQuantity Int? // Adjusted for mortality/harvest
  stockingDate DateTime
  estimatedHarvestDate DateTime?
  status      String   @default("ACTIVE") // ACTIVE, HARVESTED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("batches")
}

model SensorReading {
  id          String   @id @default(uuid())
  cageId      String
  cage        Cage     @relation(fields: [cageId], references: [id])
  temperature Float?
  ph          Float?
  dissolvedOxygen Float?
  turbidity   Float?
  ammonia     Float?
  timestamp   DateTime @default(now())

  @@map("sensor_readings")
}
