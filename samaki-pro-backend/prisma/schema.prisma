generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ... Enums are supported by Prisma client mapping ...

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique // Links to Supabase Auth User ID
  fullName  String?
  role      String   @default("FARMER") // SQLite doesn't support native enums well in migrations sometimes, but Prisma handles it. 
  // actually simpler to use String for SQLite to avoid issues, but let's try Enum first.
  // Prisma recommends String for SQLite if native enums are issues.
  // But let's stick to Enum and see if Prisma handles it (it usually maps to string).
  phone     String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings     Listing[]
  buyerOrders  Order[]   @relation("BuyerOrders")
  sellerOrders Order[]   @relation("SellerOrders")
  cages        Cage[]

  @@map("profiles")
}

model Listing {
  id          String        @id @default(uuid())
  title       String
  description String?
  price       Decimal       // Removed @db.Decimal
  quantity    Int
  unit        String
  imageUrl    String?
  status      String        @default("AVAILABLE") // Changed to String for SQLite safety
  sellerId    String
  seller      Profile       @relation(fields: [sellerId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  orders Order[]

  @@map("listings")
}

model Order {
  id          String      @id @default(uuid())
  buyerId     String
  buyer       Profile     @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId    String
  seller      Profile     @relation("SellerOrders", fields: [sellerId], references: [id])
  listingId   String
  listing     Listing     @relation(fields: [listingId], references: [id])
  quantity    Int
  unitPrice   Decimal     // Removed @db.Decimal
  totalAmount Decimal     // Removed @db.Decimal
  escrowId    String?
  transactionId String?
  paymentProvider String?
  status      String      @default("PENDING") // Changed to String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("orders")
}

model Escrow {
  id            String   @id @default(uuid())
  orderId       String   @unique
  buyerId       String
  sellerId      String
  amount        Decimal  // Removed @db.Decimal
  transactionId String?
  status        String   @default("AWAITING_PAYMENT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("escrows")
}

model Cage {
  id          String   @id @default(uuid())
  name        String
  type        String   // "circular", "rectangular"
  length      Float?
  width       Float?
  depth       Float?
  capacity    Int?     // Max fish capacity
  location    String?  // GPS coordinates or description
  farmerId    String
  farmer      Profile  @relation(fields: [farmerId], references: [id])
  status      String   @default("ACTIVE") // ACTIVE, MAINTENANCE, INACTIVE
  
  batches     Batch[]
  sensors     SensorReading[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cages")
}

model Batch {
  id          String   @id @default(uuid())
  cageId      String
  cage        Cage     @relation(fields: [cageId], references: [id])
  species     String   // "Tilapia", "Nile Perch"
  quantity    Int      // Initial stocking quantity
  currentQuantity Int? // Adjusted for mortality/harvest
  stockingDate DateTime
  estimatedHarvestDate DateTime?
  status      String   @default("ACTIVE") // ACTIVE, HARVESTED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("batches")
}

model SensorReading {
  id          String   @id @default(uuid())
  cageId      String
  cage        Cage     @relation(fields: [cageId], references: [id])
  temperature Float?
  ph          Float?
  dissolvedOxygen Float?
  turbidity   Float?
  ammonia     Float?
  timestamp   DateTime @default(now())

  @@map("sensor_readings")
}

// ------------------------------------------------------
// Phase 3 Additions: AIoT & Fintech Advanced Modules
// ------------------------------------------------------

model CreditScore {
    id          String   @id @default(uuid())
    farmerId    String   @unique
    farmer      Profile  @relation(fields: [farmerId], references: [id])
    score       Int      // 0 - 1000
    riskLevel   String   // LOW, MEDIUM, HIGH
    loanLimit   Decimal
    lastUpdated DateTime @default(now())
    history     String?  // JSON string storing calculation metrics
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@map("credit_scores")
}

model InsurancePolicy {
    id            String   @id @default(uuid())
    cageId        String   @unique
    cage          Cage     @relation(fields: [cageId], references: [id])
    farmerId      String
    farmer        Profile  @relation(fields: [farmerId], references: [id])
    premiumAmount Decimal
    coverageLimit Decimal
    status        String   @default("ACTIVE") // ACTIVE, TRIGGERED, PAID_OUT, CANCELLED
    triggerData   String?  // JSON string storing the sensor data that triggered it
    startDate     DateTime @default(now())
    endDate       DateTime
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@map("insurance_policies")
}

// ------------------------------------------------------
// Phase 4 Additions: Traceability, Blue Carbon, Assets
// ------------------------------------------------------

model ExportPassport {
    id            String   @id @default(uuid())
    batchId       String   @unique
    batch         Batch    @relation(fields: [batchId], references: [id])
    farmerId      String
    farmer        Profile  @relation(fields: [farmerId], references: [id])
    hashData      String   // Mock cryptographic hash
    waterQuality  String   // 'Pass', 'Fail'
    issueDate     DateTime @default(now())

    @@map("export_passports")
}

model CarbonCredit {
    id            String   @id @default(uuid())
    farmerId      String   
    farmer        Profile  @relation(fields: [farmerId], references: [id])
    batchId       String
    batch         Batch    @relation(fields: [batchId], references: [id])
    tokensEarned  Decimal  // Mock carbon tokens based on biomass
    status        String   @default("AVAILABLE") // AVAILABLE, SOLD
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@map("carbon_credits")
}

model ColdChainAsset {
    id            String   @id @default(uuid())
    vendorId      String
    vendor        Profile  @relation(fields: [vendorId], references: [id])
    assetType     String   // e.g., 'Solar Cooler 50L'
    totalCost     Decimal
    amountPaid    Decimal  @default(0)
    status        String   @default("LEASING") // LEASING, OWNED, DEFAULTED
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    @@map("cold_chain_assets")
}
